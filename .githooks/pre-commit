#!/bin/sh
# Quality gate: cargo fmt --check, cargo clippy -D warnings, cargo test.
# Installed via `git config core.hooksPath .githooks`.

set -e

echo "pre-commit: checking formatting (cargo fmt --check)..."
if ! cargo fmt --check; then
    echo "pre-commit: FAILED - formatting issues found. Run 'cargo fmt' and try again." >&2
    exit 1
fi

echo "pre-commit: running clippy (cargo clippy --all-targets -- -D warnings)..."
if ! cargo clippy --all-targets -- -D warnings; then
    echo "pre-commit: FAILED - clippy warnings found. Fix them and try again." >&2
    exit 1
fi

echo "pre-commit: running tests (cargo test --quiet)..."
if ! cargo test --quiet; then
    echo "pre-commit: FAILED - tests are failing. Fix them and try again." >&2
    exit 1
fi

echo "pre-commit: all gates passed."
exit 0
